---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/ScrollReveal';
import ReadingProgressBar from '../../components/ReadingProgressBar';
import FloatingToc from '../../components/FloatingToc';
import { getCollection } from 'astro:content';
import { BASE_PATH, BLOG_PATH } from '../../utils/base';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const backlinks = posts.filter((p) => p.slug !== post.slug && (p.body || '').includes(`[[${post.data.title}]]`));
    return {
      params: { slug: post.slug },
      props: { post, backlinks },
    };
  });
}

const { post, backlinks } = Astro.props;
const { Content, headings } = await post.render();

// 计算阅读时长
function calculateReadingTime(text: string): number {
  // 去除 markdown 语法，提取纯文本
  const plainText = text
    .replace(/[#*`~>]/g, '')           // 移除 markdown 语法符号
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')  // 移除链接，保留链接文本
    .replace(/!\[([^\]]*)\]\([^)]+\)/g, '')    // 移除图片
    .replace(/```[\s\S]*?```/g, '')    // 移除代码块
    .replace(/---/g, '')               // 移除分隔线
    .replace(/\n\s*\n/g, '\n')         // 移除多余空行
    .trim();

  // 统计中文字符数和英文字符数
  let chineseChars = 0;
  let englishChars = 0;
  
  for (const char of plainText) {
    if (/[\u4e00-\u9fa5]/.test(char)) {
      chineseChars++;
    } else if (/[a-zA-Z]/.test(char)) {
      englishChars++;
    }
  }

  // 计算公式：中文/300 + 英文/200，向上取整
  const chineseMinutes = Math.ceil(chineseChars / 300);
  const englishMinutes = Math.ceil(englishChars / 200);
  
  // 返回总时长，至少1分钟
  return Math.max(1, chineseMinutes + englishMinutes);
}

const readingTime = calculateReadingTime(post.body);
---

<BaseLayout title={post.data.title}>
  <ReadingProgressBar client:load />
  <FloatingToc headings={headings} client:load />
  <main class="min-h-screen bg-white dark:bg-gray-950">
    <article class="container mx-auto px-4 py-16 max-w-4xl">
      <ScrollReveal client:load>
        <div class="mb-8">
          <a href={BASE_PATH} class="inline-flex items-center gap-2 text-purple-500 hover:text-purple-600 dark:text-purple-400 dark:hover:text-purple-300 transition-colors">
            ← 返回首页
          </a>
        </div>
      </ScrollReveal>

      <ScrollReveal client:load delay={100}>
        <header class="mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-6 title-gradient">{post.data.title}</h1>
          <div class="flex flex-wrap items-center gap-4 mb-6">
            <span class="text-2xl">
              {post.data.status === 'seed' ? '🌱' : post.data.status === 'growing' ? '🌿' : '🌳'}
            </span>
            <span class="text-gray-500 dark:text-gray-400">
              {new Date(post.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
            <span class="text-gray-500 dark:text-gray-400 flex items-center gap-1">
              🕒 预计阅读 {readingTime} 分钟
            </span>
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-sm rounded-full">{tag}</span>
              ))}
            </div>
          )}
        </header>
      </ScrollReveal>

      <ScrollReveal client:load delay={200}>
        <article class="markdown-content" data-pagefind-body>
          <Content />
        </article>
      </ScrollReveal>

      {backlinks.length > 0 && (
        <ScrollReveal client:load delay={300}>
          <section class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-800">
            <h2 class="text-xl font-bold mb-6 bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500 dark:from-emerald-300 dark:via-teal-300 dark:to-cyan-300 bg-clip-text text-transparent">链接到这篇文章</h2>
            <div class="grid gap-4">
              {backlinks.map((linkPost) => (
                <a href={`${BLOG_PATH}/${linkPost.slug}`} class="block p-4 bg-gray-50/50 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-xl hover:bg-gray-100 dark:hover:bg-white/10 transition-colors group">
                  <h3 class="text-lg font-bold mb-1 title-gradient group-hover:drop-shadow-[0_0_8px_rgba(52,211,153,0.5)] transition-all">{linkPost.data.title}</h3>
                  <p class="text-gray-500 dark:text-gray-400 text-sm">{linkPost.data.description}</p>
                </a>
              ))}
            </div>
          </section>
        </ScrollReveal>
      )}
    </article>
  </main>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const titleToSlug = {
      '欢迎来到我的数字花园': 'hello-garden',
      '设计系统构建': 'design-system',
      'AI辅助编程': 'ai-coding',
    };
    const basePath = '/digital-garden';
    const markdownContent = document.querySelector('.markdown-content');
    if (!markdownContent) return;
    const regex = /\[\[([^\]]+)\]\]/g;
    const walker = document.createTreeWalker(markdownContent, NodeFilter.SHOW_TEXT, null, false);
    const nodesToReplace = [];
    let node;
    while ((node = walker.nextNode())) {
      if (regex.test(node.textContent)) nodesToReplace.push(node);
    }
    nodesToReplace.forEach((textNode) => {
      const parent = textNode.parentElement;
      if (!parent) return;
      const text = textNode.textContent;
      regex.lastIndex = 0;
      let match, lastIndex = 0;
      const fragment = document.createDocumentFragment();
      while ((match = regex.exec(text)) !== null) {
        if (match.index > lastIndex) fragment.appendChild(document.createTextNode(text.slice(lastIndex, match.index)));
        const title = match[1];
        const slug = titleToSlug[title] || title.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
        const link = document.createElement('a');
        link.href = `${basePath}/blog/${slug}`;
        link.className = 'wikilink';
        link.dataset.slug = slug;
        link.textContent = title;
        fragment.appendChild(link);
        lastIndex = match.index + match[0].length;
      }
      if (lastIndex < text.length) fragment.appendChild(document.createTextNode(text.slice(lastIndex)));
      parent.replaceChild(fragment, textNode);
    });
  });
</script>
