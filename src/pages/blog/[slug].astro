---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/ScrollReveal';
import ReadingProgressBar from '../../components/ReadingProgressBar';
import FloatingToc from '../../components/FloatingToc';
import { getCollection } from 'astro:content';
import { BASE_PATH, BLOG_PATH } from '../../utils/base';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const backlinks = posts.filter((p) => p.slug !== post.slug && (p.body || '').includes(`[[${post.data.title}]]`));
    return {
      params: { slug: post.slug },
      props: { post, backlinks },
    };
  });
}

const { post, backlinks } = Astro.props;
const { Content, headings } = await post.render();
---

<BaseLayout title={post.data.title}>
  <ReadingProgressBar client:load />
  <FloatingToc headings={headings} client:load />
  <main class="min-h-screen bg-gray-950">
    <article class="container mx-auto px-4 py-16 max-w-4xl">
      <ScrollReveal client:load>
        <div class="mb-8">
          <a href={BASE_PATH} class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 transition-colors">
            ← 返回首页
          </a>
        </div>
      </ScrollReveal>

      <ScrollReveal client:load delay={100}>
        <header class="mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-white via-emerald-300 to-cyan-300 bg-clip-text text-transparent">{post.data.title}</h1>
          <div class="flex flex-wrap items-center gap-4 mb-6">
            <span class="text-2xl">
              {post.data.status === 'seed' ? '🌱' : post.data.status === 'growing' ? '🌿' : '🌳'}
            </span>
            <span class="text-gray-400">
              {new Date(post.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="px-3 py-1 bg-gray-800 text-gray-300 text-sm rounded-full">{tag}</span>
              ))}
            </div>
          )}
        </header>
      </ScrollReveal>

      <ScrollReveal client:load delay={200}>
        <article class="markdown-content" data-pagefind-body>
          <Content />
        </article>
      </ScrollReveal>

      {backlinks.length > 0 && (
        <ScrollReveal client:load delay={300}>
          <section class="mt-16 pt-8 border-t border-gray-800">
            <h2 class="text-xl font-bold text-white mb-6">链接到这篇文章</h2>
            <div class="grid gap-4">
              {backlinks.map((linkPost) => (
                <a href={`${BLOG_PATH}/${linkPost.slug}`} class="block p-4 bg-white/5 backdrop-blur-md border border-white/10 rounded-xl hover:bg-white/10 transition-colors">
                  <h3 class="text-lg font-bold text-white mb-1">{linkPost.data.title}</h3>
                  <p class="text-gray-400 text-sm">{linkPost.data.description}</p>
                </a>
              ))}
            </div>
          </section>
        </ScrollReveal>
      )}
    </article>
  </main>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const titleToSlug = {
      '欢迎来到我的数字花园': 'hello-garden',
      '设计系统构建': 'design-system',
      'AI辅助编程': 'ai-coding',
    };
    const basePath = '/digital-garden';
    const markdownContent = document.querySelector('.markdown-content');
    if (!markdownContent) return;
    const regex = /\[\[([^\]]+)\]\]/g;
    const walker = document.createTreeWalker(markdownContent, NodeFilter.SHOW_TEXT, null, false);
    const nodesToReplace = [];
    let node;
    while ((node = walker.nextNode())) {
      if (regex.test(node.textContent)) nodesToReplace.push(node);
    }
    nodesToReplace.forEach((textNode) => {
      const parent = textNode.parentElement;
      if (!parent) return;
      const text = textNode.textContent;
      regex.lastIndex = 0;
      let match, lastIndex = 0;
      const fragment = document.createDocumentFragment();
      while ((match = regex.exec(text)) !== null) {
        if (match.index > lastIndex) fragment.appendChild(document.createTextNode(text.slice(lastIndex, match.index)));
        const title = match[1];
        const slug = titleToSlug[title] || title.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
        const link = document.createElement('a');
        link.href = `${basePath}/blog/${slug}`;
        link.className = 'wikilink';
        link.dataset.slug = slug;
        link.textContent = title;
        fragment.appendChild(link);
        lastIndex = match.index + match[0].length;
      }
      if (lastIndex < text.length) fragment.appendChild(document.createTextNode(text.slice(lastIndex)));
      parent.replaceChild(fragment, textNode);
    });
  });
</script>
