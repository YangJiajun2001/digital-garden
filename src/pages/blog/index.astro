---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogFilter from '../../components/BlogFilter';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<BaseLayout title="思维花园 - 博客">
  <div class="min-h-screen bg-white dark:bg-gray-950">
    <div class="container mx-auto px-4 py-12 max-w-6xl">
      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="text-gray-900 dark:text-white mr-2">📝</span>
          <span class="bg-gradient-to-r from-gray-900 via-purple-500 to-pink-500 dark:from-white dark:via-purple-300 dark:to-pink-300 bg-clip-text text-transparent">文章</span>
        </h1>
        <p class="text-gray-500 dark:text-gray-400 text-lg">
          探索数字花园中的所有文章
        </p>
      </header>

      <BlogFilter posts={posts} client:load />
    </div>
  </div>
</BaseLayout>
