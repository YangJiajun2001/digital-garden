---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogFilter from '../../components/BlogFilter';
import { getCollection } from 'astro:content';
import { BASE_PATH } from '../../utils/base';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const notesPosts = await getCollection('notes');

  const allTags = new Set<string>();

  blogPosts.forEach(post => {
    if (post.data.tags) {
      post.data.tags.forEach(tag => allTags.add(tag));
    }
  });

  notesPosts.forEach(post => {
    if (post.data.tags) {
      post.data.tags.forEach(tag => allTags.add(tag));
    }
  });

  return Array.from(allTags).map(tag => ({
    params: { tag },
    props: { tagName: tag },
  }));
}

const { tag } = Astro.params;
const { tagName } = Astro.props;

const blogPosts = await getCollection('blog');
const notesPosts = await getCollection('notes');

const filteredBlogPosts = blogPosts.filter(post =>
  post.data.tags && post.data.tags.includes(tagName)
).map(post => ({ ...post, collection: 'blog' }));

const filteredNotesPosts = notesPosts.filter(post =>
  post.data.tags && post.data.tags.includes(tagName)
).map(post => ({ ...post, collection: 'notes' }));

const allPosts = [...filteredBlogPosts, ...filteredNotesPosts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={`${tagName} - 标签`}>
  <div class="min-h-screen bg-white dark:bg-gray-950">
    <div class="container mx-auto px-4 py-12 max-w-6xl">
      <header class="mb-12">
        <a
          href={`${BASE_PATH}/tags`}
          class="inline-flex items-center gap-2 text-emerald-500 hover:text-emerald-400 mb-4 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          返回标签星图
        </a>
        <h1 class="text-4xl md:text-5xl font-bold mb-4 flex items-center gap-3">
          <span>🏷️</span>
          <span class="bg-gradient-to-r from-emerald-400 via-teal-400 to-cyan-400 bg-clip-text text-transparent">
            {tagName}
          </span>
        </h1>
        <p class="text-gray-500 dark:text-gray-400 text-lg">
          找到 {allPosts.length} 篇相关文章
        </p>
      </header>

      <BlogFilter posts={allPosts} client:load />
    </div>
  </div>
</BaseLayout>
