---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterGrid from '../components/FilterGrid';
import ScrollReveal from '../components/ScrollReveal';
import Heatmap from '../components/Heatmap';
import TypewriterHero from '../components/TypewriterHero';
import { getCollection } from 'astro:content';
import { GARDEN_PATH } from '../utils/base';

const posts = await getCollection('blog');
const notes = await getCollection('notes');

const blogItems = posts.map((post) => ({
  slug: post.slug,
  type: 'blog' as const,
  data: {
    title: post.data.title,
    description: post.data.description,
    pubDate: post.data.pubDate,
    status: post.data.status,
    tags: post.data.tags || [],
  },
}));

const noteItems = notes.map((note) => ({
  slug: note.slug,
  type: 'note' as const,
  data: {
    title: note.data.title,
    content: note.data.content,
    pubDate: note.data.pubDate,
    tags: note.data.tags || [],
  },
}));

const allItems = [...blogItems, ...noteItems];

const heatmapItems = [
  ...posts.map((post) => ({
    pubDate: post.data.pubDate,
    content: post.body,
  })),
  ...notes.map((note) => ({
    pubDate: note.data.pubDate,
    content: note.data.content,
  })),
];

// 计算站点数据统计
const stats = {
  articles: posts.length,
  notes: notes.length,
  totalWords: posts.reduce((acc, post) => acc + post.body.length, 0) + notes.reduce((acc, note) => acc + note.data.content.length, 0),
  tags: [...new Set([...posts.flatMap(p => p.data.tags || []), ...notes.flatMap(n => n.data.tags || [])])].length,
  evergreen: posts.filter(p => p.data.status === 'evergreen').length,
};
---

<BaseLayout title="思维花园 - 播种想法，培育认知">
  <main class="min-h-screen bg-white dark:bg-gray-950 relative z-10">
    <TypewriterHero client:load />

    <section class="container mx-auto px-4 py-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 max-w-4xl mx-auto">
        {[
          { icon: '📝', value: stats.articles, label: '文章总数' },
          { icon: '💡', value: stats.notes, label: '闪念胶囊数' },
          { icon: '📊', value: stats.totalWords.toLocaleString(), label: '总字数' },
          { icon: '🏷️', value: stats.tags, label: '标签总数' },
          { icon: '🌳', value: stats.evergreen, label: '常青文章' },
        ].map((stat, index) => (
          <ScrollReveal key={index} client:load delay={index * 100}>
            <div class="group relative p-4 rounded-2xl bg-white/50 dark:bg-gray-900/50 backdrop-blur-md border border-gray-200 dark:border-gray-800 hover:border-emerald-400/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-emerald-500/10">
              <div class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-gray-100 mb-1">
                {stat.icon} {stat.value}
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400">
                {stat.label}
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </section>

    <section class="container mx-auto px-4 py-8">
      <ScrollReveal client:load delay={300}>
        <div class="text-center mb-6">
          <div class="inline-flex items-center gap-2.5">
            <span class="text-2xl">🌱</span>
            <h2 class="text-2xl md:text-3xl font-bold tracking-wide bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500 dark:from-emerald-300 dark:via-teal-300 dark:to-cyan-300 bg-clip-text text-transparent">
              花园灌溉轨迹
            </h2>
          </div>
          <p class="text-sm mt-2 font-medium tracking-wider uppercase text-gray-400 dark:text-gray-500">
            Garden Watering Trajectory
          </p>
        </div>
        <Heatmap items={heatmapItems} client:load />
      </ScrollReveal>
    </section>

    <section class="container mx-auto px-4 pb-16">
      <ScrollReveal client:load delay={400}>
        <FilterGrid items={allItems} client:load />
      </ScrollReveal>
    </section>
  </main>
</BaseLayout>
