---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterGrid from '../components/FilterGrid';
import ScrollReveal from '../components/ScrollReveal';
import Heatmap from '../components/Heatmap';
import { getCollection } from 'astro:content';
import { GARDEN_PATH } from '../utils/base';

const posts = await getCollection('blog');
const notes = await getCollection('notes');

const blogItems = posts.map((post) => ({
  slug: post.slug,
  type: 'blog' as const,
  data: {
    title: post.data.title,
    description: post.data.description,
    pubDate: post.data.pubDate,
    status: post.data.status,
    tags: post.data.tags || [],
  },
}));

const noteItems = notes.map((note) => ({
  slug: note.slug,
  type: 'note' as const,
  data: {
    title: note.data.title,
    content: note.data.content,
    pubDate: note.data.pubDate,
    tags: note.data.tags || [],
  },
}));

const allItems = [...blogItems, ...noteItems];

const heatmapItems = [
  ...posts.map((post) => ({
    pubDate: post.data.pubDate,
    content: post.body,
  })),
  ...notes.map((note) => ({
    pubDate: note.data.pubDate,
    content: note.data.content,
  })),
];
---

<BaseLayout title="思维花园 - 播种想法，培育认知">
  <main class="min-h-screen bg-gray-950 relative z-10">
    <section class="container mx-auto px-4 py-16 text-center">
      <ScrollReveal client:load>
        <div class="flex justify-center gap-4 mb-8">
          <a
            href={GARDEN_PATH}
            class="group px-6 py-2.5 bg-purple-600/20 hover:bg-purple-600/30 text-purple-300 hover:text-purple-200 rounded-lg transition-all duration-300 border border-purple-600/30 hover:border-purple-500/50 backdrop-blur-sm"
          >
            <span class="flex items-center gap-2.5 btn-text">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 013.001-3.001h1.987a.75.75 0 01.75.75v11.998a3.001 3.001 0 01-3.001 3.001H3.36m11.14 0a3.001 3.001 0 003.001-3.001V15a.75.75 0 00-.75-.75h-2.25" />
              </svg>
              知识图谱
            </span>
          </a>
        </div>
      </ScrollReveal>

      <ScrollReveal client:load delay={100}>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold mb-6 font-sans tracking-tight flex flex-col md:flex-row items-center justify-center gap-4 group cursor-pointer">
          <span class="text-6xl md:text-7xl lg:text-8xl transition-transform duration-300 group-hover:scale-110">🌿</span>
          <span class="bg-gradient-to-r from-emerald-400 via-teal-400 to-cyan-400 bg-clip-text text-transparent group-hover:from-emerald-300 group-hover:via-teal-300 group-hover:to-cyan-300 transition-all duration-300 group-hover:drop-shadow-[0_0_30px_rgba(52,211,153,0.5)]">思维花园</span>
        </h1>
      </ScrollReveal>

      <ScrollReveal client:load delay={200}>
        <p class="text-xl md:text-2xl lg:text-3xl text-gray-400 font-light tracking-wide mt-2">
          播种想法，培育认知
        </p>
        <p class="text-base md:text-lg text-gray-500 mt-4 max-w-2xl mx-auto font-normal">
          在这片数字花园中，记录思考的点滴，让知识自然生长
        </p>
      </ScrollReveal>
    </section>

    <section class="container mx-auto px-4 py-8">
      <ScrollReveal client:load delay={300}>
        <div class="text-center mb-6">
          <div class="inline-flex items-center gap-2.5">
            <span class="text-2xl">🌱</span>
            <h2 class="text-2xl md:text-3xl font-bold tracking-wide bg-gradient-to-r from-emerald-300 via-teal-300 to-cyan-300 bg-clip-text text-transparent">
              花园灌溉轨迹
            </h2>
          </div>
          <p class="text-sm mt-2 font-medium tracking-wider uppercase bg-gradient-to-r from-gray-500 to-gray-400 bg-clip-text text-transparent">
            Garden Watering Trajectory
          </p>
        </div>
        <Heatmap items={heatmapItems} client:load />
      </ScrollReveal>
    </section>

    <section class="container mx-auto px-4 pb-16">
      <ScrollReveal client:load delay={400}>
        <FilterGrid items={allItems} client:load />
      </ScrollReveal>
    </section>
  </main>
</BaseLayout>
