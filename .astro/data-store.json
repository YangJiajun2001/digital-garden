[["Map",1,2,9,10,38,39,111,112],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.1","content-config-digest","f0e8faaa4f6d3341","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","now",["Map",11,12],"index",{"id":11,"data":13,"body":15,"filePath":16,"digest":17,"rendered":18,"legacyId":37},{"lastUpdated":14},["Date","2026-05-21T00:00:00.000Z"],"## 📍 当前聚焦\n\n最近正在深入学习 **人工智能与机器学习** 领域，特别是大语言模型的应用和微调技术。尝试将 AI 能力整合到日常工作流中，提升开发效率。同时也在探索向量数据库和知识图谱的构建方法。\n\n## 📚 正在阅读\n\n- 《深入理解计算机系统》第三版 - 重温底层原理，夯实计算机基础知识\n- 《代码大全》第二版 - 学习优秀的编程实践和代码设计原则\n- 《The Little Book of Deep Learning》 - 入门深度学习理论\n\n## 🌱 正在培育\n\n花园里有几篇文章正在生长中：\n\n- **React 性能优化指南** - 整理常见的性能优化技巧和最佳实践\n- **TypeScript 高级类型** - 深入讲解 TypeScript 的类型系统和高级用法\n- **数字花园理念** - 探索数字花园的构建哲学和知识管理方法\n\n期待这些种子能够茁壮成长，成为有价值的常青文章！","src/content/now/index.md","cfec9f2e4bfe89d9",{"html":19,"metadata":20},"\u003Ch2 id=\"-当前聚焦\">📍 当前聚焦\u003C/h2>\n\u003Cp>最近正在深入学习 \u003Cstrong>人工智能与机器学习\u003C/strong> 领域，特别是大语言模型的应用和微调技术。尝试将 AI 能力整合到日常工作流中，提升开发效率。同时也在探索向量数据库和知识图谱的构建方法。\u003C/p>\n\u003Ch2 id=\"-正在阅读\">📚 正在阅读\u003C/h2>\n\u003Cul>\n\u003Cli>《深入理解计算机系统》第三版 - 重温底层原理，夯实计算机基础知识\u003C/li>\n\u003Cli>《代码大全》第二版 - 学习优秀的编程实践和代码设计原则\u003C/li>\n\u003Cli>《The Little Book of Deep Learning》 - 入门深度学习理论\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"-正在培育\">🌱 正在培育\u003C/h2>\n\u003Cp>花园里有几篇文章正在生长中：\u003C/p>\n\u003Cul>\n\u003Cli>\u003Cstrong>React 性能优化指南\u003C/strong> - 整理常见的性能优化技巧和最佳实践\u003C/li>\n\u003Cli>\u003Cstrong>TypeScript 高级类型\u003C/strong> - 深入讲解 TypeScript 的类型系统和高级用法\u003C/li>\n\u003Cli>\u003Cstrong>数字花园理念\u003C/strong> - 探索数字花园的构建哲学和知识管理方法\u003C/li>\n\u003C/ul>\n\u003Cp>期待这些种子能够茁壮成长，成为有价值的常青文章！\u003C/p>",{"headings":21,"localImagePaths":32,"remoteImagePaths":33,"frontmatter":34,"imagePaths":36},[22,26,29],{"depth":23,"slug":24,"text":25},2,"-当前聚焦","📍 当前聚焦",{"depth":23,"slug":27,"text":28},"-正在阅读","📚 正在阅读",{"depth":23,"slug":30,"text":31},"-正在培育","🌱 正在培育",[],[],{"lastUpdated":35},["Date","2026-05-21T00:00:00.000Z"],[],"index.md","blog",["Map",40,41,64,65,87,88],"ai-coding",{"id":40,"data":42,"body":50,"filePath":51,"digest":52,"rendered":53,"legacyId":63},{"title":43,"description":44,"pubDate":45,"status":46,"tags":47},"AI辅助编程","用AI写代码的体验",["Date","2023-10-20T00:00:00.000Z"],"seed",[48,49],"技术","AI","AI辅助编程正在改变我们写代码的方式。从代码补全到自动生成，AI工具正在成为开发者的得力助手。\n\n使用AI写代码有很多好处：\n- 提高开发效率\n- 减少重复劳动\n- 帮助学习新技术\n- 提供代码审查建议\n\n当然，AI也不是万能的。它生成的代码需要仔细审查，确保正确性和安全性。但不可否认的是，AI正在成为开发者工具箱中不可或缺的一部分。\n\n未来，AI辅助编程的能力还会不断提升，让我们拭目以待。","src/content/blog/ai-coding.md","ee9b22fed83ba831",{"html":54,"metadata":55},"\u003Cp>AI辅助编程正在改变我们写代码的方式。从代码补全到自动生成，AI工具正在成为开发者的得力助手。\u003C/p>\n\u003Cp>使用AI写代码有很多好处：\u003C/p>\n\u003Cul>\n\u003Cli>提高开发效率\u003C/li>\n\u003Cli>减少重复劳动\u003C/li>\n\u003Cli>帮助学习新技术\u003C/li>\n\u003Cli>提供代码审查建议\u003C/li>\n\u003C/ul>\n\u003Cp>当然，AI也不是万能的。它生成的代码需要仔细审查，确保正确性和安全性。但不可否认的是，AI正在成为开发者工具箱中不可或缺的一部分。\u003C/p>\n\u003Cp>未来，AI辅助编程的能力还会不断提升，让我们拭目以待。\u003C/p>",{"headings":56,"localImagePaths":57,"remoteImagePaths":58,"frontmatter":59,"imagePaths":62},[],[],[],{"title":43,"description":44,"pubDate":60,"status":46,"tags":61},"2023-10-20",[48,49],[],"ai-coding.md","design-system",{"id":64,"data":66,"body":73,"filePath":74,"digest":75,"rendered":76,"legacyId":86},{"title":67,"description":68,"pubDate":69,"status":70,"tags":71},"设计系统构建","关于设计的思考",["Date","2023-10-10T00:00:00.000Z"],"growing",[72],"设计","设计系统是现代前端开发的重要组成部分。它不仅仅是一套UI组件库，更是一套完整的设计语言和规范。\n\n一个好的设计系统应该包含：\n- 设计原则和价值观\n- 色彩系统和排版规范\n- 可复用的UI组件\n- 设计模式和最佳实践\n\n构建设计系统是一个持续迭代的过程。它需要设计师和开发者的紧密协作，不断地收集反馈、优化改进。\n\n通过建立统一的设计语言，可以极大地提高团队的工作效率，确保产品体验的一致性。","src/content/blog/design-system.md","f415af46e5c8d566",{"html":77,"metadata":78},"\u003Cp>设计系统是现代前端开发的重要组成部分。它不仅仅是一套UI组件库，更是一套完整的设计语言和规范。\u003C/p>\n\u003Cp>一个好的设计系统应该包含：\u003C/p>\n\u003Cul>\n\u003Cli>设计原则和价值观\u003C/li>\n\u003Cli>色彩系统和排版规范\u003C/li>\n\u003Cli>可复用的UI组件\u003C/li>\n\u003Cli>设计模式和最佳实践\u003C/li>\n\u003C/ul>\n\u003Cp>构建设计系统是一个持续迭代的过程。它需要设计师和开发者的紧密协作，不断地收集反馈、优化改进。\u003C/p>\n\u003Cp>通过建立统一的设计语言，可以极大地提高团队的工作效率，确保产品体验的一致性。\u003C/p>",{"headings":79,"localImagePaths":80,"remoteImagePaths":81,"frontmatter":82,"imagePaths":85},[],[],[],{"title":67,"description":68,"pubDate":83,"status":70,"tags":84},"2023-10-10",[72],[],"design-system.md","hello-garden",{"id":87,"data":89,"body":97,"filePath":98,"digest":99,"rendered":100,"legacyId":110},{"title":90,"description":91,"pubDate":92,"status":93,"tags":94},"欢迎来到我的数字花园","这是第一篇文章",["Date","2023-10-01T00:00:00.000Z"],"evergreen",[95,96],"思考","元","欢迎来到我的数字花园！这里是我记录想法、分享知识的地方。\n\n数字花园是一种新型的写作方式，它不像传统博客那样追求完美的文章，而是像园丁培育植物一样，让想法慢慢生长、演化。每一篇笔记都是一个种子，随着时间的推移，它们会相互连接、生长，形成一个有机的知识网络。\n\n在这个花园里，你会发现各种主题的思考和探索。有些内容可能还在萌芽阶段（seed），有些正在成长（growing），还有一些已经成熟稳定（evergreen）。\n\n如果你对设计系统感兴趣，可以看看 [[设计系统构建]]。","src/content/blog/hello-garden.md","99462c9296db086e",{"html":101,"metadata":102},"\u003Cp>欢迎来到我的数字花园！这里是我记录想法、分享知识的地方。\u003C/p>\n\u003Cp>数字花园是一种新型的写作方式，它不像传统博客那样追求完美的文章，而是像园丁培育植物一样，让想法慢慢生长、演化。每一篇笔记都是一个种子，随着时间的推移，它们会相互连接、生长，形成一个有机的知识网络。\u003C/p>\n\u003Cp>在这个花园里，你会发现各种主题的思考和探索。有些内容可能还在萌芽阶段（seed），有些正在成长（growing），还有一些已经成熟稳定（evergreen）。\u003C/p>\n\u003Cp>如果你对设计系统感兴趣，可以看看 [[设计系统构建]]。\u003C/p>",{"headings":103,"localImagePaths":104,"remoteImagePaths":105,"frontmatter":106,"imagePaths":109},[],[],[],{"title":90,"description":91,"pubDate":107,"status":93,"tags":108},"2023-10-01",[95,96],[],"hello-garden.md","notes",["Map",113,114,136,137,157,158],"2026-05-20-react-hooks",{"id":113,"data":115,"filePath":123,"digest":124,"rendered":125,"legacyId":135},{"title":116,"content":117,"pubDate":118,"tags":119},"React Hooks 的一点小思考","最近在用 React Hooks 时发现，useEffect 的依赖数组真的很容易出错。每次修改状态都要检查一遍依赖，感觉心智负担有点重。有没有更好的方式来管理副作用呢？",["Date","2026-05-20T00:00:00.000Z"],[120,121,122],"React","Hooks","Frontend","src/content/notes/2026-05-20-react-hooks.md","62298a2a59914a52",{"html":126,"metadata":127},"",{"headings":128,"localImagePaths":129,"remoteImagePaths":130,"frontmatter":131,"imagePaths":134},[],[],[],{"title":116,"content":117,"pubDate":132,"tags":133},["Date","2026-05-20T00:00:00.000Z"],[120,121,122],[],"2026-05-20-react-hooks.md","2026-05-21-astro-love",{"id":136,"data":138,"filePath":145,"digest":146,"rendered":147,"legacyId":156},{"content":139,"pubDate":140,"tags":141},"Astro 5.x 的新特性太棒了！特别是那个 content collections，让内容管理变得超级简单。再也不用手动写 frontmatter 类型定义了。",["Date","2026-05-21T00:00:00.000Z"],[142,143,144],"Astro","SSG","JavaScript","src/content/notes/2026-05-21-astro-love.md","8456fe6a49cb37ba",{"html":126,"metadata":148},{"headings":149,"localImagePaths":150,"remoteImagePaths":151,"frontmatter":152,"imagePaths":155},[],[],[],{"content":139,"pubDate":153,"tags":154},["Date","2026-05-21T00:00:00.000Z"],[142,143,144],[],"2026-05-21-astro-love.md","2026-05-19-ai-future",{"id":157,"data":159,"filePath":166,"digest":167,"rendered":168,"legacyId":177},{"title":160,"content":161,"pubDate":162,"tags":163},"AI 的未来在哪里？","看了很多关于 AI Agent 的文章，感觉这可能是下一个大趋势。想象一下，多个 AI 智能体协作完成复杂任务，这画面太美了。",["Date","2026-05-19T00:00:00.000Z"],[49,164,165],"Machine Learning","Future","src/content/notes/2026-05-19-ai-future.md","acb43f30e6159373",{"html":126,"metadata":169},{"headings":170,"localImagePaths":171,"remoteImagePaths":172,"frontmatter":173,"imagePaths":176},[],[],[],{"title":160,"content":161,"pubDate":174,"tags":175},["Date","2026-05-19T00:00:00.000Z"],[49,164,165],[],"2026-05-19-ai-future.md"]